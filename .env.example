# ============================================
# SmartDesk AI — Nail Salon Automation
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# ---- VONAGE (primary SMS/WhatsApp) ----
VONAGE_API_KEY=your_vonage_api_key
VONAGE_API_SECRET=your_vonage_api_secret
VONAGE_FROM_NUMBER=+1XXXXXXXXXX
VONAGE_WHATSAPP_NUMBER=+1XXXXXXXXXX

# ---- TWILIO (fallback / US SMS) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ---- OPENAI ----
OPENAI_API_KEY=sk-...

# ---- AIRTABLE ----
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_CLIENTS_TABLE=Clients
AIRTABLE_APPOINTMENTS_TABLE=Appointments
AIRTABLE_MESSAGES_TABLE=Messages

# ---- RETELL AI (Voice) ----
RETELL_API_KEY=your_retell_api_key
RETELL_AGENT_ID=your_bella_agent_id

# ---- n8n ----
N8N_WEBHOOK_URL=https://your-n8n-instance.com
N8N_WEBHOOK_PATH=/webhook/nail-salon-inbound

# ---- SALON INFO ----
SALON_NAME=Your Nail Salon Name
SALON_PHONE=+1XXXXXXXXXX
SALON_ADDRESS=123 Main St, City, State
SALON_GOOGLE_REVIEW_URL=https://g.page/r/XXXXX/review
SALON_YELP_URL=https://www.yelp.com/biz/your-salon

# ---- CALENDLY (optional) ----
CALENDLY_API_KEY=your_calendly_api_key
CALENDLY_EVENT_URL=https://calendly.com/your-salon/appointment
