  "__readme__": {
    "title": "SmartDesk AI — Nail Salon Automation Workflow",
    "price": "$799/month",
    "variables_required": [
      "RETELL_API_KEY — Your Retell AI API key",
      "TWILIO_ACCOUNT_SID — Twilio account SID",
      "TWILIO_AUTH_TOKEN — Twilio auth token",
      "TWILIO_FROM_NUMBER — Your Twilio phone number (e.g. +15315416041)",
      "AIRTABLE_BASE_ID — Your Airtable base ID for nail salon CRM",
      "STYLIST_EMAIL — Email of the default stylist to notify",
      "DEFAULT_STYLIST — Name of default stylist",
      "BOOKING_LINK — Public booking link (Calendly or similar)",
      "GOOGLE_REVIEW_LINK — Google Maps review link for the salon",
      "LOYALTY_CODE — Discount code for returning clients",
      "AI_AGENT_ACTIVE — Set to 'true' when AI agent is live"
    ],
    "setup_steps": [
      "1. Import this JSON into n8n",
      "2. Set all variables under Settings > Variables",
      "3. Configure Airtable credentials (OAuth or API key)",
      "4. Configure Twilio credentials",
      "5. Configure Slack credentials (or replace with Twilio SMS)",
      "6. Set your Retell AI agent_id (current: agent_d4e806f2be5ef25d5ea61c17de)",
      "7. In Twilio console, set the 'A message comes in' webhook for your phone number to: https://<your-n8n-host>/webhook/twilio-sms-reply",
      "8. Create inquiry webhook trigger in Meta Business Suite or Zapier pointing to: https://<your-n8n-host>/webhook/nail-salon-inquiry",
      "9. Activate workflow and test with a sample inquiry"
    ],
    "architecture_notes": [
      "Two webhook triggers: nail-salon-inquiry (intake) and twilio-sms-reply (CONFIRM/CANCEL replies).",
      "A Set node after Airtable create captures the record ID and restores original client fields so all downstream nodes can reference $json.name, $json.phone, $json.crm_record_id reliably.",
      "Client CONFIRM/CANCEL replies are handled by the inbound SMS webhook, not by polling after the reminder send.",
      "The loyalty offer fires 3 days after the review request — detecting an actual Google review requires a Google My Business webhook outside this workflow."
    ]
  }
}
